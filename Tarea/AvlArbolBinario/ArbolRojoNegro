class NodoRN:
    def __init__(self, valor):
        self.valor = valor
        self.color = "rojo"  # nuevo nodo siempre rojo
        self.izq = None
        self.der = None
        self.padre = None


class ArbolRN:
    def __init__(self):
        self.raiz = None


    # Rotación izquierda
    def rotar_izquierda(self, x):
        y = x.der
        x.der = y.izq

        if y.izq:
            y.izq.padre = x

        y.padre = x.padre

        if not x.padre:
            self.raiz = y
        elif x == x.padre.izq:
            x.padre.izq = y
        else:
            x.padre.der = y

        y.izq = x
        x.padre = y


    # Inserción iterativa
    def insertar(self, valor):
        nuevo = NodoRN(valor)
        y = None
        x = self.raiz

        # Inserción tipo BST
        while x:
            y = x
            if valor < x.valor:
                x = x.izq
            else:
                x = x.der

        nuevo.padre = y

        if not y:
            self.raiz = nuevo
        elif valor < y.valor:
            y.izq = nuevo
        else:
            y.der = nuevo

        # Arreglar propiedades
        self.fix_insert(nuevo)


    # Corrección del árbol
    def fix_insert(self, k):
        while k.padre and k.padre.color == "rojo":
            # Aquí irían todos los casos (simplificado)
            k.padre.color = "negro"

        self.raiz.color = "negro"